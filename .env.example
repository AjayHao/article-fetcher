# ========== 必需配置 ==========

# 阿里云 OSS 图床
ALIYUN_OSS_AK=your_oss_access_key_here
ALIYUN_OSS_SK=your_oss_secret_key_here
ALIYUN_OSS_BUCKET_ID=your_bucket_id_here
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Notion 存档
NOTION_API_KEY=your_notion_integration_token_here
NOTION_ARTICLE_DATABASE_ID=your_notion_database_id_here

# ========== 可选配置 ==========

# 调试模式（true/false）
DEBUG=false

# Cookies 文件路径（用于反爬，可选）
# WECHAT_COOKIES_FILE=/path/to/wechat_cookies.txt
# XHS_COOKIES_FILE=/path/to/xhs_cookies.txt
# ZHIHU_COOKIES_FILE=/path/to/zhihu_cookies.txt
